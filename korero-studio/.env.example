# Copy to .env.local in THIS folder (same as package.json). Save the file and restart `npm run dev`.
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
# Use either the publishable key OR the legacy anon key (same variable role):
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Admin access is not configured via env. Set profiles.app_role = 'admin' in the database (see README / Admin → Users).

# Optional: server-only — WhatsApp Cloud API (Meta) + follow-up rows in Supabase
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_NOTIFY_ADMIN_E164=6591234567
# SUPABASE_SERVICE_ROLE_KEY=
